PDF_PASSWORD=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Set to "outlook" (default) or "gmail"
MAIL_PROVIDER=outlook

# Outlook — required when MAIL_PROVIDER=outlook
AZURE_CLIENT_ID=

# Gmail — required when MAIL_PROVIDER=gmail
# (no env vars needed; drop gmail_credentials.json into the /data volume)

# Override the sender filter (default: statement@emiratesnbd.com)
# Useful when forwarding emails — set to your forwarding address
EMAIL_SENDER_FILTER=